[sub_resource type="GDScript" id="GDScript_negdo"]
script/source = "extends Button

func _pressed() -> void:
	var loaded_scene: Node = get_tree().root.get_node(^\"MainStage/LoadedScene\")
	loaded_scene.get_child(0).visible = false
	var main_level := preload(\"res://scenes/levels/MainLevel.tscn\")
	loaded_scene.add_child(main_level.instantiate())
"

[sub_resource type="GDScript" id="GDScript_n3jsm"]
script/source = "extends Button

func _pressed() -> void:
