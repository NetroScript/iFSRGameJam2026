"

[sub_resource type="GDScript" id="GDScript_jes8i"]
script/source = "extends Button


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	if OS.has_feature(\"web\"):
		hide()

func _pressed() -> void:
	get_tree().quit()
"

